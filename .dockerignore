# Keep the build context lean and avoid leaking local state into the image.
.git
.github
.venv
venv
evidence/
**/__pycache__
**/*.pyc
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
*_mock.svg
# Never bake secrets into the image — they're injected at RUNTIME via compose
# env_file. .dockerignore matching is path-anchored (NOT recursive like
# .gitignore), so exclude env files at the root AND in any subdir (e.g. deploy/.env).
.env
.env.*
**/.env
**/.env.*
# Manifests ARE baked into the image: `manifests/` (the folder the TUI builds
# into) is copied in at build time so the scheduler can run them by path. Build
# and test your manifests before `docker compose build`; rebuild to pick up edits.
# (Still excluded: the legacy scratch `manifest.yaml` at the repo root.)
manifest.yaml
