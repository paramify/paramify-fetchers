# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
*.whl
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtualenv ---
.venv/
venv/

# --- Secrets: NEVER commit ---
# The framework resolves ${env:VAR} from the environment; .env is one source
# among many and must stay local.
.env
.env.*
!.env.example

# --- Generated collect output (runner writes evidence/run-<timestamp>/) ---
/evidence/

# --- Local working manifests ---
# The manifest builder writes ./manifest.yaml by default; the welcome picker
# also scans manifests/*.yaml. Both are customer-side working files; canonical
# samples live in examples/. Delete these lines to commit your own.
/manifest.yaml
/manifests/

# --- Claude Code: ignore personal settings, keep shared skills + settings.json ---
.claude/settings.local.json
.claude/tmp/

# --- Terraform: never commit the local provider cache or state ---
# .terraform/ holds platform-specific provider binaries (hundreds of MiB);
# .terraform.lock.hcl IS committed (it pins provider versions).
.terraform/
*.tfstate
*.tfstate.*

# --- TUI design preview renders (regenerable; open locally) ---
*_mock.svg

# --- VHS demo recordings: scratch dir is throwaway; the .tape/.gif ARE committed ---
docs/demo/.scratch/

# --- macOS / editors ---
.DS_Store
.idea/
.vscode/
*.swp
